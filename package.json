    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron-to-chromium": "^1.5.376",
    "eslint": "^9.0.0",
    "rollup": "4.62.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
